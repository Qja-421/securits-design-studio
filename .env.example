# ─────────────────────────────────────────────────────────────
# Securits Tech — Variables d'environnement
# Copier ce fichier en .env et renseigner vos valeurs
# ─────────────────────────────────────────────────────────────

# Gemini API Key (Google AI Studio)
# Obtenez votre clé sur https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=

# ─── Firebase (Cloud Sync — optionnel, activer en Phase 2) ───
# Créer un projet sur https://console.firebase.google.com
# puis copier la configuration SDK ci-dessous
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ─────────────────────────────────────────────────────────────
# NOTE : Tant que VITE_FIREBASE_* est vide, la persistance
# reste locale via IndexedDB (Dexie.js) — aucune synchro cloud.
# ─────────────────────────────────────────────────────────────
